# MongoDB Connection URI (Local or Atlas)
MONGO_URI=mongodb://localhost:27017/Growup
# Alternative MongoDB Atlas URI:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/Growup

# Cloudinary Configuration (For pitch deck, images, and videos upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Server Configuration
PORT=5000

# JSON Web Token Secret for Authentication
JWT_SECRET=your_jwt_secret_key

# Google Calendar Integration (For booking appointments between founders and investors)
GOOGLE_CALENDAR_ID=your_google_calendar_email@gmail.com
